# Public routes are fixture-only. These values are used only by the local,
# explicitly invoked live-evidence command.
ENABLE_OPENAI_LIVE=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=medium

# Optional local Story Workbench lane. Live HTTP requests require the flag,
# a loopback host, and the same high-entropy token in a private request header.
# Generate a token locally with: openssl rand -hex 32
PENELOPE_STORY_CODEX_CLI_ENABLED=0
PENELOPE_STORY_CODEX_CLI_TOKEN=
# Optional absolute path or safe command name. On macOS the app-bundled Codex
# binary is preferred automatically when this value is unset.
PENELOPE_CODEX_CLI_COMMAND=
