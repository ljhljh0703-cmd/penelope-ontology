{
  "name": "narrative-ontology-harness",
  "version": "0.0.0",
  "private": true,
  "description": "A provenance-aware narrative rehearsal harness for creator-controlled canon, style, and state transitions.",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/verify-next-trace-privacy.mjs",
    "prebuild:identified": "node scripts/assert-clean-build.mjs",
    "build:identified": "next build",
    "postbuild:identified": "node scripts/verify-next-trace-privacy.mjs",
    "start": "next start",
    "lint": "eslint .",
    "pretypecheck": "node --import tsx scripts/normalize-next-type-cache.ts",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "smoke:deployment": "node scripts/smoke-deployment.mjs",
    "submission:check": "node --import tsx scripts/verify-submission-readiness.ts --phase pre-submit",
    "submission:check:post": "node --import tsx scripts/verify-submission-readiness.ts --phase post-submit",
    "evidence": "node --import tsx scripts/generate-evidence.ts",
    "evidence:live:approve": "node --import tsx scripts/create-live-capture-approval.ts --mode primary --request-sha b341c779b81a03bda66a5d3c6c18146df7bb92750e49d594a161fac7e07fc1c7",
    "evidence:live:preflight": "node --env-file-if-exists=.env.local --import tsx scripts/preflight-live-evidence.ts",
    "evidence:live:capture": "node --env-file-if-exists=.env.local --import tsx scripts/capture-live-evidence.ts",
    "evidence:live": "npm run evidence:live:capture",
    "evidence:live:retry:approve": "node --import tsx scripts/create-live-capture-approval.ts --mode retry --request-sha b341c779b81a03bda66a5d3c6c18146df7bb92750e49d594a161fac7e07fc1c7",
    "evidence:live:retry:preflight": "node --env-file-if-exists=.env.local --import tsx scripts/preflight-live-evidence.ts --retry",
    "evidence:live:retry:capture": "node --env-file-if-exists=.env.local --import tsx scripts/capture-live-evidence.ts --retry",
    "evidence:live:retry": "npm run evidence:live:retry:capture",
    "evidence:live:review": "node --import tsx scripts/prepare-live-creator-review.ts",
    "evidence:live:finalize": "node --import tsx scripts/finalize-live-creator-decision.ts",
    "evidence:codex-cli:review": "node --import tsx scripts/prepare-codex-cli-review.ts",
    "evidence:codex-cli:approve": "node --import tsx scripts/approve-codex-cli-capture.ts",
    "evidence:codex-cli:preflight": "node --import tsx scripts/preflight-codex-cli-evidence.ts",
    "evidence:codex-cli:capture": "node --import tsx scripts/capture-codex-cli-evidence.ts",
    "evidence:codex-cli:retry:review": "node --import tsx scripts/prepare-codex-cli-review.ts --retry",
    "evidence:codex-cli:retry:approve": "node --import tsx scripts/approve-codex-cli-capture.ts --retry",
    "evidence:codex-cli:retry:preflight": "node --import tsx scripts/preflight-codex-cli-evidence.ts --retry",
    "evidence:codex-cli:retry:capture": "node --import tsx scripts/capture-codex-cli-evidence.ts --retry",
    "myth-atlas:intake": "node --import tsx scripts/intake-myth-atlas.ts",
    "myth-atlas:compatibility": "node --import tsx scripts/report-myth-atlas-compatibility.ts",
    "eval:style:capture": "node --env-file-if-exists=.env.local --import tsx scripts/capture-style-ablation.ts",
    "eval:style:report": "node --import tsx scripts/finalize-style-ablation.ts",
    "evidence:verify": "node scripts/verify-evidence.mjs",
    "privacy": "node scripts/privacy-scan.mjs",
    "privacy:next-trace": "node scripts/verify-next-trace-privacy.mjs",
    "verify": "npm run evidence && npm run evidence:verify && npm run lint && npm run typecheck && npm run test && npm run privacy && npm run build",
    "verify:identified": "npm run evidence && npm run evidence:verify && npm run lint && npm run typecheck && npm run test && npm run privacy && npm run build:identified",
    "verify:release": "npm run verify && npm run test:browser",
    "verify:release:identified": "npm run verify:identified && npm run test:browser"
  },
  "dependencies": {
    "next": "16.2.10",
    "openai": "6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
